#include <iostream>
#include <algorithm>
#include <vector>

using namespace std;
int main() {
int n;
cin >> n;
vector <int> a(n);
for(int i = 0; i < n; i++) cin >> a[i];
sort(a.begin(), a.end(), [](int x, int y) {
        bool xEven = (x % 2 == 0);
        bool yEven = (y % 2 == 0);

        
        if (xEven && !yEven) return true;
        if (!xEven && yEven) return false;

        
        if (xEven && yEven) return x > y;

    
        return x < y;
    });

    for (int x : a) cout << x << " ";
    return 0;
}







