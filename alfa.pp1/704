#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n;

    if (n < 0) n = -n; // на случай отрицательных чисел

    bool valid = true;

    while (n > 0) {
        int digit = n % 10; // последняя цифра
        if (digit % 2 != 0) { // нечётная
            valid = false;
            break; // можно сразу остановиться
        }
        n /= 10; // убираем последнюю цифру
    }

    if (valid)
        cout << "Valid" << endl;
    else
        cout << "Not valid" << endl;

    return 0;
}
